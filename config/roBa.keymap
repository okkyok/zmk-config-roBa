#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/mouse-gesture.h>

#define ZMK_POINTING_DEFAULT_SCRL_VAL 100

// Layer index aliases
#define BASE   0
#define SYMBOL 1
#define NUM    2
#define ARROW  3
#define BT_L   4
#define MOUSE  5
#define SCROLL 6
#define L7     7
#define L8     8
#define L9     9

&mt {
    flavor = "balanced";
    quick-tap-ms = <0>;
};

&lt {
    flavor = "balanced";
    quick-tap-ms = <300>;
};

&trackball {
    // Auto mouse layer is now driven by &zip_temp_layer (see roBa_R.overlay).
    scroll-layers = <SCROLL>;
};

/ {
    combos {
        compatible = "zmk,combos";

        tab {
            bindings = <&kp TAB>;
            key-positions = <11 12>;
        };

        shift_tab {
            bindings = <&kp LS(TAB)>;
            key-positions = <12 13>;
        };

        muhennkann {
            bindings = <&to_layer_0 INT_MUHENKAN>;
            key-positions = <11 10>;
        };

        double_quotation {
            bindings = <&kp DOUBLE_QUOTES>;
            key-positions = <20 21>;
        };

        eq {
            bindings = <&kp EQUAL>;
            key-positions = <24 25>;
        };

        gesture_l8 {
            bindings = <&mo L8>;
            key-positions = <8 9>;
        };

        gesture_l9 {
            bindings = <&mo L9>;
            key-positions = <19 20>;
        };
    };

    macros {
        to_layer_0: to_layer_0 {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
            label = "TO_LAYER_0";
        };

        // NOTE: 動画版の mul_mark / div_mark の実際の出力が不明のため、
        // テンキーの × (KP_MULTIPLY) / ÷ (KP_DIVIDE) を暫定割当。
        mul_mark: mul_mark {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp KP_MULTIPLY>;
            label = "MUL_MARK";
        };

        div_mark: div_mark {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp KP_DIVIDE>;
            label = "DIV_MARK";
        };

        // Force-exits the MOUSE auto layer on tap (see mt_exit_AML_on_tap below),
        // so typing can resume immediately instead of waiting for the
        // zip_temp_layer idle timeout.
        exit_AML: exit_AML {
            compatible = "zmk,behavior-macro";
            wait-ms = <0>;
            tap-ms = <0>;
            #binding-cells = <0>;
            bindings = <&tog_off MOUSE>;
            label = "exit_AML";
        };

        kp_exit_AML: kp_exit_AML {
            compatible = "zmk,behavior-macro-one-param";
            wait-ms = <0>;
            tap-ms = <0>;
            #binding-cells = <1>;
            bindings = <&macro_param_1to1 &kp MACRO_PLACEHOLDER &exit_AML>;
            label = "KP_exit_AML";
        };
    };

    behaviors {
        lt_to_layer_0: lt_to_layer_0 {
            compatible = "zmk,behavior-hold-tap";
            label = "LAYER_TAP_TO_0";
            bindings = <&mo>, <&to_layer_0>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
        };

        scroll_up_down: scroll_up_down {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;

            tap-ms = <20>;
        };

        scroll_right_left: scroll_right_left {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_LEFT>, <&msc SCRL_RIGHT>;

            tap-ms = <20>;
        };

        tog_off: toggle_layer_off {
            compatible = "zmk,behavior-toggle-layer";
            #binding-cells = <1>;
            display-name = "Toggle Layer Off";
            toggle-mode = "off";
        };

        mt_exit_AML_on_tap: mt_exit_AML_on_tap {
            compatible = "zmk,behavior-hold-tap";
            label = "MT_exit_AML_ON_TAP";
            bindings = <&kp>, <&kp_exit_AML>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "balanced";
            quick-tap-ms = <200>;
        };
    };

    zip_mouse_gesture_l7: zip_mouse_gesture_l7 {
        compatible = "zmk,input-processor-mouse-gesture";
        #input-processor-cells = <0>;
        always-active;
        enable-eager-mode;
        suppress-movement;
        stroke-size = <5>;
        movement-threshold = <6>;
        idle-timeout-ms = <100>;
        gesture-cooldown-ms = <120>;

        // Tab management
        prev_tab  { pattern = <GESTURE_LEFT>;  bindings = <&kp LC(LS(TAB))>; };
        next_tab  { pattern = <GESTURE_RIGHT>; bindings = <&kp LC(TAB)>;     };
        new_tab   { pattern = <GESTURE_UP>;    bindings = <&kp LG(T)>;      };
        close_tab { pattern = <GESTURE_DOWN>;  bindings = <&kp LG(W)>;       };
    };

    zip_mouse_gesture_l8: zip_mouse_gesture_l8 {
        compatible = "zmk,input-processor-mouse-gesture";
        #input-processor-cells = <0>;
        always-active;
        enable-eager-mode;
        suppress-movement;
        stroke-size = <5>;
        movement-threshold = <6>;
        idle-timeout-ms = <100>;
        gesture-cooldown-ms = <120>;

        // Virtual desktop (Mission Control space) management
        desk_prev    { pattern = <GESTURE_LEFT>;  bindings = <&kp LC(LEFT_ARROW)>;  };
        desk_next    { pattern = <GESTURE_RIGHT>; bindings = <&kp LC(RIGHT_ARROW)>; };
        mission_ctrl { pattern = <GESTURE_UP>;    bindings = <&kp LC(UP_ARROW)>;    };
        app_expose   { pattern = <GESTURE_DOWN>;  bindings = <&kp LC(DOWN_ARROW)>;  };
    };

    zip_mouse_gesture_l9: zip_mouse_gesture_l9 {
        compatible = "zmk,input-processor-mouse-gesture";
        #input-processor-cells = <0>;
        always-active;
        enable-eager-mode;
        suppress-movement;
        stroke-size = <5>;
        movement-threshold = <6>;
        idle-timeout-ms = <100>;
        gesture-cooldown-ms = <120>;

        // App switching / quick actions
        prev_app  { pattern = <GESTURE_LEFT>;  bindings = <&kp LG(LS(TAB))>; };
        next_app  { pattern = <GESTURE_RIGHT>; bindings = <&kp LG(TAB)>;     };
        focus_url { pattern = <GESTURE_UP>;    bindings = <&kp LG(L)>;       };
        spotlight { pattern = <GESTURE_DOWN>;  bindings = <&kp LG(SPACE)>;   };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp Q             &kp W  &kp E     &kp R         &kp T                                                      &kp Y              &kp U        &kp I      &kp O    &lt SCROLL P
&mt LCTRL A       &mt LS(LGUI) S  &mt LALT D     &mt LGUI F         &mt LCTRL G        &kp LS(TAB)                  &mt RC(RS(RA(RGUI))) SEMICOLON  &mt RCTRL H              &mt RGUI J        &mt RALT K      &mt RS(RGUI) L    &lt L7 MINUS
&mt_exit_AML_on_tap LEFT_SHIFT Z  &kp X  &kp C     &kp V         &kp B        &lt MOUSE TAB                  &kp DOUBLE_QUOTES  &kp N          &kp M        &kp COMMA  &kp DOT  &mt LEFT_SHIFT SLASH
&kp LGUI          &kp LALT  &kp LGUI  &lt BT_L LANG2  &lt NUM SPACE  &lt_to_layer_0 ARROW LANG1      &kp BACKSPACE  &lt SYMBOL ENTER                             &lt MOUSE ESC
            >;

            sensor-bindings = <&scroll_up_down>;
        };

        symbol_layer {
            bindings = <
&trans               &kp AMPERSAND    &kp ASTERISK  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS                       &trans  &kp LEFT_BRACKET       &kp RIGHT_BRACKET      &trans         &trans
&kp EXCL             &kp DQT          &kp HASH      &kp DLLR              &kp PRCNT              &trans      &trans  &kp AMPS  &kp SQT                &kp LPAR                &kp RPAR       &trans
&mt LEFT_SHIFT MINUS &kp EXCLAMATION  &kp AT_SIGN   &kp HASH              &trans                 &trans      &trans  &trans  &kp LEFT_BRACE         &kp RIGHT_BRACE        &kp PIPE       &trans
&trans               &trans           &trans        &trans                &trans                 &trans      &trans  &trans                                                                &trans
            >;

            sensor-bindings = <&scroll_right_left>;
        };

        num_layer {
            bindings = <
&kp F1        &kp F2     &kp F3     &kp F4     &kp F5                                             &kp SLASH   &kp EQUAL  &kp ASTERISK  &kp PLUS  &kp PERCENT
&kp NUMBER_1        &kp NUMBER_2  &kp NUMBER_3  &kp NUMBER_4  &kp NUMBER_5      &trans                &mul_mark  &kp NUMBER_6      &kp NUMBER_7  &kp NUMBER_8  &kp NUMBER_9  &kp NUMBER_0
&kp F6     &kp F7  &kp F8  &kp F9  &kp F10      &kp KP_MULTIPLY       &div_mark  &kp F11      &kp F12  &kp COMMA  &kp DOT  &kp DOLLAR
&trans        &trans     &trans     &trans     &trans            &trans                &trans     &trans                             &trans
            >;

            sensor-bindings = <&scroll_up_down>;
        };

        arrow_layer {
            // 右手側はWindows用ショートカット(Win+矢印スナップ, PrintScreen系)。Mac利用時は要調整。
            bindings = <
&kp PG_UP  &trans          &kp UP_ARROW    &trans           &kp PG_DN                                        &trans  &kp LC(LA(Y))               &kp LA(LC(UP_ARROW))  &kp LC(LA(U))             &trans
&kp HOME   &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT_ARROW  &kp END      &trans        &kp LC(LG(PRINTSCREEN))  &trans  &kp LA(LC(LEFT_ARROW))  &kp LA(LC(DOWN_ARROW))  &kp LA(LC(RIGHT_ARROW))  &trans
&trans     &trans          &trans          &trans           &trans      &trans        &kp LS(PRINTSCREEN)      &trans  &kp LC(LA(H))               &kp LC(LA(J))             &trans             &trans
&trans     &trans          &trans          &trans           &trans      &trans        &kp DELETE               &trans                                          &trans
            >;

            sensor-bindings = <&inc_dec_kp LC(TAB) LC(LS(TAB))>;
        };

        bt_layer {
            bindings = <
&kp TAB  &trans  &trans  &trans  &trans                             &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4
&kp LEFT_SHIFT  &trans  &trans  &trans  &trans      &trans         &trans  &trans        &kp LS(TAB)        &trans        &kp TAB        &trans
&trans  &trans  &trans  &trans  &trans      &trans      &bootloader  &trans      &trans        &trans        &trans        &bt BT_CLR
&trans  &trans  &kp LGUI  &trans  &trans      &trans      &trans       &kp LGUI                                                &bt BT_CLR_ALL
            >;

            sensor-bindings = <&scroll_up_down>;
        };

        mouse_layer {
            bindings = <
&trans  &trans  &trans  &trans  &trans                          &trans  &trans     &trans     &trans     &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans  &mkp MB1   &mkp MB3   &mkp MB2   &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans  &mkp MB4   &trans     &mkp MB5   &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans                                   &trans
            >;

            sensor-bindings = <&scroll_up_down>;
        };

        scroll_layer {
            bindings = <
&trans  &trans  &trans  &trans  &trans                          &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans                          &trans
            >;

            sensor-bindings = <&scroll_up_down>;
        };

        Gesture_L7 {
            // Trackball gestures only; keys stay inert. See zip_mouse_gesture_l7.
            bindings = <
&trans  &trans  &trans  &trans  &trans                          &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans                          &trans
            >;

            sensor-bindings = <&scroll_up_down>;
        };

        Gesture_L8 {
            // Trackball gestures only; keys stay inert. See zip_mouse_gesture_l8.
            bindings = <
&trans  &trans  &trans  &trans  &trans                          &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans                          &trans
            >;

            sensor-bindings = <&scroll_up_down>;
        };

        Gesture_L9 {
            // Trackball gestures only; keys stay inert. See zip_mouse_gesture_l9.
            bindings = <
&trans  &trans  &trans  &trans  &trans                          &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans      &trans  &trans                          &trans
            >;

            sensor-bindings = <&scroll_up_down>;
        };
    };
};
